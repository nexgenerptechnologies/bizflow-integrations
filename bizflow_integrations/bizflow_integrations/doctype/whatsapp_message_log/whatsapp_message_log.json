{
    "naming_rule":  "By \"Naming Series\" field",
    "autoname":  "naming_series:",
    "permissions":  [
                        {
                            "export":  1,
                            "write":  1,
                            "delete":  1,
                            "report":  1,
                            "role":  "System Manager",
                            "read":  1,
                            "share":  1,
                            "create":  1
                        }
                    ],
    "issingle":  0,
    "name":  "WhatsApp Message Log",
    "module":  "BizFlow Integrations",
    "doctype":  "DocType",
    "custom":  0,
    "fields":  [
                   {
                       "label":  "Series",
                       "fieldtype":  "Select",
                       "reqd":  1,
                       "options":  "WA-LOG-.YY.-",
                       "fieldname":  "naming_series"
                   },
                   {
                       "label":  "Mobile Number",
                       "fieldtype":  "Data",
                       "reqd":  1,
                       "in_list_view":  1,
                       "fieldname":  "mobile_number"
                   },
                   {
                       "fieldname":  "direction",
                       "label":  "Direction",
                       "in_list_view":  1,
                       "fieldtype":  "Select",
                       "options":  "Outgoing\nIncoming",
                       "reqd":  1
                   },
                   {
                       "fieldname":  "status",
                       "label":  "Status",
                       "in_list_view":  1,
                       "default":  "Queued",
                       "fieldtype":  "Select",
                       "options":  "Queued\nSent\nDelivered\nRead\nFailed"
                   },
                   {
                       "label":  "Message Text",
                       "fieldtype":  "Text",
                       "in_list_view":  1,
                       "fieldname":  "message_text"
                   },
                   {
                       "label":  "Reference Document Type",
                       "fieldtype":  "Link",
                       "options":  "DocType",
                       "fieldname":  "reference_doctype"
                   },
                   {
                       "label":  "Reference Document Name",
                       "fieldtype":  "Dynamic Link",
                       "options":  "reference_doctype",
                       "fieldname":  "reference_name"
                   }
               ]
}
